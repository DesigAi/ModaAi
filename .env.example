# GEMINI_API_KEY: Required for future Gemini AI API calls.
# Do not commit a real key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ModaAI frontend data mode.
# demo = local contract-compatible demo store for client demos.
# http = reserved for future real backend adapter; currently fail-fast until backend contracts exist.
VITE_API_MODE="demo"
VITE_API_BASE_URL="http://localhost:8080"
